            <mxPoint x="345" y="790" as="sourcePoint"/>
            <mxPoint x="210" y="790" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="msg26" value="Show result" style="endArrow=block;html=1;strokeColor:#000000;fillColor:#000000;fontSize:10;" edge="1" parent="1">
