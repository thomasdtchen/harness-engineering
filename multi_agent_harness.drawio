        </mxCell>
        <mxCell id="msg20" value="" style="endArrow=block;html=1;strokeColor:#E84A8C;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="345" y="660" as="sourcePoint"/>
            <mxPoint x="905" y="660" as="targetPoint"/>
