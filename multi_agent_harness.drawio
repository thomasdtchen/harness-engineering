        <mxCell id="msg22" value="return review result" style="endArrow=block;html=1;strokeColor:#E84A8C;fillColor:#E84A8C;dashed=1;fontSize:10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="905" y="720" as="sourcePoint"/>
            <mxPoint x="345" y="720" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Alt: Review Pass -->
        <mxCell id="alt-pass" value="alt&#10;Review passed" style="rounded=1;whiteSpace=wrap;html=1;fillColor:#E5F6E9;strokeColor:#3DBC74;fontSize:10;align=center;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="220" y="740" width="1080" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="msg23" value="Mark task complete" style="rounded=1;whiteSpace=wrap;html=1;fillColor:#E5F6E9;strokeColor:#3DBC74;fontSize:10;" vertex="1" parent="1">
          <mxGeometry x="350" y="760" width="100" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="msg24" value="" style="endArrow=block;html=1;strokeColor:#4A86E8;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="345" y="770" as="sourcePoint"/>
            <mxPoint x="1180" y="770" as="targetPoint"/>
