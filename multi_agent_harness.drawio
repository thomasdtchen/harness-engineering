        <!-- Review -->
        <mxCell id="msg21" value="review(final_draft, trajectory)" style="endArrow=block;html=1;strokeColor:#000000;fillColor:#000000;fontSize:10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="345" y="690" as="sourcePoint"/>
            <mxPoint x="905" y="690" as="targetPoint"/>
