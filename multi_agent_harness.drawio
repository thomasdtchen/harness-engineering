        <mxCell id="msg29" value="return revised result" style="endArrow=block;html=1;strokeColor:#E84A8C;fillColor:#E84A8C;fontSize:10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="345" y="850" as="sourcePoint"/>
            <mxPoint x="210" y="850" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Footer -->
        <mxCell id="footer" value="Orchestrate | Plan | Execute | Review | Decide" style="rounded=1;whiteSpace=wrap;html=1;fillColor:#4A86E8;strokeColor:#000000;fontColor:#FFFFFF;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="200" y="900" width="120" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="footer2" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor:#3DBC74;strokeColor:#000000;fontColor:#FFFFFF;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="320" y="900" width="120" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="footer3" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor:#7B61FF;strokeColor:#000000;fontColor:#FFFFFF;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="440" y="900" width="120" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="footer4" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor:#F7B500;strokeColor:#000000;fontColor:#000000;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="560" y="900" width="120" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="footer5" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor:#E84A8C;strokeColor:#000000;fontColor:#FFFFFF;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="680" y="900" width="120" height="30" as="geometry"/>
        </mxCell>

        <!-- Legend -->
        <mxCell id="legend" value="Multi-Agent Harness Core Mechanisms" style="rounded=1;whiteSpace=wrap;html=1;fillColor:#E5F1FF;strokeColor:#4A86E8;fontSize:11;fontStyle=bold;" vertex="1" parent="1">
          <mxGeometry x="1400" y="180" width="200" height="250" as="geometry"/>
