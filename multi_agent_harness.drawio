        <mxCell id="msg27" value="Execute revision steps" style="endArrow=block;html=1;strokeColor:#000000;fillColor:#000000;fontSize:10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="345" y="820" as="sourcePoint"/>
            <mxPoint x="625" y="820" as="targetPoint"/>
