        <mxCell id="alt-revise" value="else&#10;Needs revision" style="rounded=1;whiteSpace=wrap;html=1;fillColor:#FFE5E5;strokeColor:#E84A8C;fontSize:10;align=center;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="220" y="800" width="1080" height="80" as="geometry"/>
